# BFF Proxy configuration
# Copy to .env and fill in values

# Secret used to sign JWTs — change this to a random 64-char string in production
JWT_SECRET=change-me-to-a-random-64-char-string

# JWT lifetime in seconds (default: 8 hours)
JWT_TTL=28800

# Comma-separated list of allowed origins for CORS
# Example: https://portal.example.com,https://staging.example.com
PORTAL_ORIGINS=http://localhost:8081,http://localhost:3000

# Port the proxy listens on
PORT=3001
